# Database Configuration
MONGO_URL=mongodb://localhost:27017/bigtech_chat
MYSQL_URL=mysql+aiomysql://chatuser:chatpass@localhost:3306/chatdb
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2
REFRESH_TOKEN_EXPIRE_HOURS=72

# CSRF Configuration
CSRF_SECRET_KEY=your-csrf-secret-key-change-in-production-please
CSRF_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=true
APP_NAME="BigTech Chat Backend"
VERSION=1.0.0

# Redis Settings
REDIS_MAX_CONNECTIONS=20
REDIS_RETRY_ON_TIMEOUT=true
REDIS_SOCKET_KEEPALIVE=true

# Rate Limiting Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Docker Compose 환경에서 사용할 설정들 (주석 해제하여 사용)
# MONGO_URL=mongodb://mongodb:27017/bigtech_chat
# MYSQL_URL=mysql+aiomysql://chatuser:chatpass@mysql:3306/chatdb
# REDIS_URL=redis://redis:6379/0
# DEBUG=false