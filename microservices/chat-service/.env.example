# Chat Service Environment Variables

# Application
APP_NAME=Chat Service
VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8002

# Database - MySQL
MYSQL_URL=mysql+aiomysql://root:password@localhost:3306/chatdb

# Database - MongoDB
MONGO_URL=mongodb://localhost:27017
MONGODB_DB_NAME=chatdb

# Database - Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094
KAFKA_TOPIC_MESSAGE_EVENTS=message.events

# JWT (User Service와 동일한 키 사용)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2

# CORS
CORS_ORIGINS=["http://localhost:3000"]
